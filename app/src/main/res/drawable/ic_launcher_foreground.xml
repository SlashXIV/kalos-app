<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — canvas total : 108dp
    Safe zone garantie : 72dp centré (inset min = 18dp de chaque côté)
    Inset 20dp → artwork à 68dp, 4dp de marge dans la safe zone
    Source : artwork blanc sur transparent (K + "11" + "Ka")
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="20dp"
        android:right="20dp"
        android:top="20dp"
        android:bottom="20dp">
        <bitmap
            android:src="@drawable/ic_launcher_artwork"
            android:gravity="fill" />
    </item>
</layer-list>
