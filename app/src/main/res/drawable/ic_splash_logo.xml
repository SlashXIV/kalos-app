<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash screen icon — Android alloue 240dp (circulaire masqué sur API 31+)
    windowSplashScreenIconBackgroundColor = #3D414B → cercle couleur carte
    Artwork K centré à 70% du diamètre du cercle → 168dp dans 240dp
    Inset = (240-168)/2 = 36dp de chaque côté
    Résultat : "carte circulaire" avec K blanc, cohérent avec l'icône launcher
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="36dp"
        android:right="36dp"
        android:top="36dp"
        android:bottom="36dp">
        <bitmap
            android:src="@drawable/ic_launcher_artwork"
            android:gravity="fill" />
    </item>
</layer-list>
